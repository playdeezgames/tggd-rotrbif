<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Turn.fs" />
    <Compile Include="CardinalDirection.fs" />
    <Compile Include="CharacterState.fs" />
    <Compile Include="MetaphorState.fs" />
    <Compile Include="StateInitializer.fs" />
    <Compile Include="MetaphorContext.fs" />
    <Compile Include="Command.fs" />
    <Compile Include="CommandHandler.fs" />
    <Compile Include="InputProcessor.fs" />
    <Compile Include="Repl.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
